# Copy to .env and fill in. Never commit your real .env.
# NOTE: No API key is required. With OCR_PROVIDER=auto and no key set, the app
# uses the local EasyOCR/Tesseract engine automatically.

# auto | gemini | openai | google_vision | local
OCR_PROVIDER=auto

# --- Optional: Gemini (used automatically only if a key is present) ---
# GEMINI_API_KEY=your_google_ai_studio_key_here
# GEMINI_MODEL=gemini-2.0-flash

# --- Optional: OpenAI GPT-4o ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# --- Optional: Google Cloud Vision ---
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json

# --- Tuning ---
MEDICINE_MATCH_THRESHOLD=72
OCR_MIN_CONFIDENCE=0.6
ENABLE_PREPROCESSING=true
